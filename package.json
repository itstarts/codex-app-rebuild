{
  "name": "codex-app-rebuild",
  "version": "0.1.0",
  "private": true,
  "description": "Personal macOS arm64 Codex Desktop rebuild toolchain",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/itstarts/codex-app-rebuild.git"
  },
  "bugs": {
    "url": "https://github.com/itstarts/codex-app-rebuild/issues"
  },
